# ---------- server ----------
APP_PORT=8080

# ---------- database ----------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/appdb?sslmode=disable

# ---------- redis / asynq ----------
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- timeouts ----------
HEALTH_CHECK_TIMEOUT=2s
API_SHUTDOWN_TIMEOUT=10s
WORKER_SHUTDOWN_TIMEOUT=30s

# ---------- logging ----------
# "stdout" = JSON to console (default, good for production)
# "file" = write to file only
# "both" = write to file AND console
LOG_OUTPUT=stdout

# Log level: debug, info (default), warn, error
LOG_LEVEL=info

# Log file path (only used when LOG_OUTPUT is "file" or "both")
# Examples: logs/api.log, /var/log/myapp/app.log
LOG_FILE=

URL_SHORTENER_SALT=

# ---------- worker schedules ----------
# Cron expression for stats aggregation (default: every 30s for dev, use "0 0 * * *" for production)
STATS_AGGREGATE_CRON=@every 30s